@model BecoSoft.FrontendTest.Web.Models.ViewModels.ProductDetailViewModel

@{
    var tags = new[] { Model.Brand, "Backpacks", "School", "Travel", "22L" };
}

<div class="py-3">
    <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
        <span>Click the logo for more products from</span>
        <a href="#" class="badge badge-primary text-decoration-none"
           aria-label="More products from @Model.Brand">
            @Model.Brand
        </a>
    </div>

    <div class="d-flex align-items-baseline flex-wrap gap-2">
        <span class="font-weight-bold mr-2">Tags</span>
        @foreach (var tag in tags)
        {
            <a href="#" class="text-muted">
                <small>@tag</small>
            </a>
        }
    </div>
</div>
