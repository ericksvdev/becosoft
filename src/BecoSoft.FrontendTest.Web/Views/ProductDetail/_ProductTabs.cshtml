@model BecoSoft.FrontendTest.Web.Models.ViewModels.ProductDetailViewModel

<div class="product-tabs">
    <ul class="nav nav-tabs text-muted flex-nowrap" id="productTabs" role="tablist">
        <li class="nav-item">
            <a class="nav-link py-3 text-nowrap active" id="tab-description" data-toggle="tab" href="#description" role="tab" aria-controls="description" aria-selected="true">
                <i class="far fa-file-alt mr-2" aria-hidden="true"></i>Description
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link py-3 text-nowrap" id="tab-reviews" data-toggle="tab" href="#reviews" role="tab" aria-controls="reviews" aria-selected="false">
                <i class="far fa-star mr-2" aria-hidden="true"></i>Reviews
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link py-3 text-nowrap" id="tab-specifications" data-toggle="tab" href="#specifications" role="tab" aria-controls="specifications" aria-selected="false">
                <i class="fas fa-sliders mr-2" aria-hidden="true"></i>Specifications
            </a>
        </li>
    </ul>

    <div class="tab-content py-4" id="productTabsContent">
        <div class="tab-pane fade show active" id="description" role="tabpanel" aria-labelledby="tab-description">
            <p class="py-3">@Model.Description</p>
        </div>
        <div class="tab-pane fade" id="reviews" role="tabpanel" aria-labelledby="tab-reviews">
            <partial name="_TabReviews" model="Model" />
        </div>
        <div class="tab-pane fade" id="specifications" role="tabpanel" aria-labelledby="tab-specifications">
            <partial name="_TabSpecifications" model="Model" />
        </div>
    </div>
</div>
