@model BecoSoft.FrontendTest.Web.Models.ViewModels.ProductDetailViewModel

<section class="related-products py-3 bg-white">
    <h3 class="related-products__title text-center text-uppercase mb-3">
        Related Products
    </h3>

    <div class="row pt-3">
        @foreach (var product in Model.RelatedProducts)
        {
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <partial name="_ProductCard" model="product" />
            </div>
        }
    </div>
</section>
