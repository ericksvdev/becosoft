@model BecoSoft.FrontendTest.Web.Models.ViewModels.ProductDetailViewModel

<div class="row justify-content-between">
    @foreach (var review in Model.Reviews)
    {
        <div class="col-12 col-md-6 mb-4">

            <div class="d-flex gap-5">
                <div class="d-flex gap-3 mb-3">
                    <div class="review-avatar mt-1">@review.Author[0]</div>
                    <div>
                        <p class="font-weight-bold mb-0">@review.Author</p>
                        <small class="text-muted">May 05, 2024</small>
                        <div class="mt-2">
                            <partial name="_StarRating" model="review.Rating" />
                        </div>
                    </div>
                </div>

                <div class="d-flex flex-column gap-2 mb-2">
                    <span class="text-success small">
                        <i class="fas fa-check-circle mr-1" aria-hidden="true"></i>All is perfect
                    </span>
                    <span class="text-danger small">
                        <i class="fas fa-times-circle mr-1" aria-hidden="true"></i>None
                    </span>
                </div>
            </div>

            <p class="mb-1">Works perfectly and is top!</p>
            <p class="card-text text-muted mb-0">@review.Comment</p>

        </div>
    }
</div>