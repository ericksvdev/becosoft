@model BecoSoft.FrontendTest.Web.Models.ViewModels.RelatedProductViewModel

@{
    var hasDiscount = Model.DiscountedPrice.HasValue && Model.DiscountedPrice.Value < Model.Price;
    var displayPrice = hasDiscount ? Model.DiscountedPrice!.Value : Model.Price;
    var discountPercent = hasDiscount
        ? (int)Math.Round((Model.Price - Model.DiscountedPrice!.Value) / Model.Price * 100)
        : 0;
}

<a href="#" class="card h-100">
    <div class="p-3">
        @if (hasDiscount)
        {
            <span class="product-card__badge--promo font-weight-normal badge badge-secondary text-primary">PROMO: @discountPercent% OFF</span>
        }
        <img src="@Model.ImageUrl"
             alt="@Model.Title"
             class="product-card__image rounded-sm"
             loading="lazy"
             decoding="async" />
    </div>

    <div class="card-body d-flex flex-column px-3 pt-3 pb-3">
        <h6 class="product-card__title text-dark mb-1">@Model.Title</h6>
        <p class="text-muted small mb-2">School &amp; Travel</p>

        <div class="d-flex flex-wrap align-items-center mb-3 gap-2">
            <partial name="_StarRating" model="4" />
            <small class="text-muted">(13)</small>
            <small class="text-muted d-block d-xl-inline border-xl-left">25 Sold</small>
        </div>

        <div class="d-flex gap-1 flex-wrap-reverse align-items-center justify-content-between mt-auto">
            <div class="d-flex align-items-start column-gap-1 flex-wrap-reverse">
                <span class="h4 text-primary mb-0">€ @displayPrice.ToString("F2")</span>
                @if (hasDiscount)
                {
                    <del class="text-muted small">€ @Model.Price.ToString("F2")</del>
                }
            </div>
            @if (hasDiscount)
            {
                <span class="badge badge-primary product-card__badge--korting">@discountPercent% OFF</span>
            }
        </div>
    </div>
</a>
