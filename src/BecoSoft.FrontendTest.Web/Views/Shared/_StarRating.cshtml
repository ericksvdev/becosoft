@model int

@{
    var normalizedRating = Math.Clamp(Model, 0, 5);
}

<span class="d-inline-flex align-items-center gap-1" aria-label="Rating: @normalizedRating of 5">
    @for (var i = 1; i <= 5; i++)
    {
        var starClass = i <= normalizedRating ? "text-secondary" : "text-muted";
        <i class="fas fa-star @starClass" aria-hidden="true"></i>
    }
</span>
